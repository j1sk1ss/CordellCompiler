function foo(i32 a) -> i32 {
    return a - 10;
}

start() {
    ptr i32 a = 0xB8400;
    ptr i32 b = 0xB8400;
    @[no_fall]
    @[straight]
    switch 1; {
        case 1; { 
            a = foo(10);
            if 1; {
                b = a;
            }
        }
        case 2; { a = 1002; }
        default { a = 1111; }
    }

    exit dref b;
}


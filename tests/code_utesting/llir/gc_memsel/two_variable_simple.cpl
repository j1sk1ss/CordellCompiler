start() {
    i32 a = 1 as i32;
    i32 b = 1 as i32;
    exit (a + b) as i8;
}

: OUTPUT
BB1: start
r15 = $1;
rsi = r15;
r15 = rsi;
r8 = r15;
r15 = $1;
rdx = r15;
r15 = rdx;
rcx = r15;
r15 = r8;
rax = r15;
rax = rax + rcx;
r15 = rax;
rdi = r15;
r15 = rdi;
r9 = r15;
r15 = r9;
rdx = r15;
exit rdx;

start() {
    i32 a = 1 as i32;
    i32 b = 1 as i32;
    if a; exit b;
    else exit a;
}

:/ OUTPUT
BB1: start
r15 = $1;
rsi = r15;
r15 = rsi;
rdx = r15;
r15 = $1;
rcx = r15;
r15 = rcx;
rax = r15;
cmp rdx, 0;
je lb29;
jne lb28;
BB2: lb28:
r15 = rax;
rdx = r15;
exit rdx;
BB3: lb29:
r15 = rdx;
rdx = r15;
exit rdx;
BB4: lb30:
/:
start() {
    arr a[10, i32];
    a[5] = 0 as i32;
}

: OUTPUT
BB1: start
r15 = $0;
rsi = r15;
r15 = &([rbp - 40]);
rdi = r15;
r15 = $5;
rax = r15;
rax = rax * 4;
r15 = rax;
rdx = r15;
r15 = rdx;
rcx = r15;
r15 = rdi;
rax = r15;
rax = rax + rcx;
r15 = rax;
rbx = r15;
r15 = rsi;
*(rbx) = r15;
kill(6);

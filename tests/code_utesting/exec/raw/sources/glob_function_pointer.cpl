function putc(i8 c) -> i0 {
    syscall(0x2000004, 1, ref c, 1);
}

function put_digit(i64 x) -> i0 {
    putc(('0' + x) as i8);
}

glob function inc(i64 a) -> i64 {
    return a + 1;
}

start() {
    ptr i0 f = inc;
    put_digit(f(8));
    exit 0;
}

